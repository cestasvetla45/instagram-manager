# ─────────────────────────────────────────────────────────────
#  Instagram Manager — environment variables
#  Copy to .env.local for local dev, or set in Vercel project settings.
# ─────────────────────────────────────────────────────────────

# ---- Airtable ----
# Create a personal access token at https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write, schema.bases:read
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appS9dwcribegqibV

# Table names (already created for you — only change if you rename them)
AIRTABLE_INSPIRATION_REELS=Inspiration Reels
AIRTABLE_INSPIRATION_ACCOUNTS=Inspiration Accounts
AIRTABLE_OUR_ACCOUNTS=Our Accounts
AIRTABLE_OUR_REELS=Our Reels
AIRTABLE_SNAPSHOTS=Metric Snapshots

# ---- RockSolidAPIs — Instagram Scraper Stable API ----
# Docs: https://rocksolidapis.auto-poster.co.uk/instagram-scraper-stable-api-docs
# The adapter is pre-wired to this provider's endpoints; you normally only
# need to set ROCKSOLID_API_KEY. Base URL and auth header have correct defaults.
ROCKSOLID_API_KEY=your_rocksolid_api_key
ROCKSOLID_BASE_URL=https://auto-poster.co.uk/yt_api
ROCKSOLID_AUTH_HEADER=AP_API_KEY

# ---- Optional: protect the dashboard with a simple shared password ----
# If set, the UI asks for this once and stores it in the browser.
APP_PASSWORD=
