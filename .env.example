# ─────────────────────────────────────────────────────────────
#  Instagram Manager — environment variables (Supabase + Railway)
#  Local dev: copy to .env.local.   Prod: set in Railway variables
#  (on BOTH the web service and the worker service).
# ─────────────────────────────────────────────────────────────

# ---- Supabase ----
# Project Settings → API. The service-role key is SECRET (server-side only).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- RockSolidAPIs — Instagram Scraper Stable API ----
# Adapter is pre-wired; you normally only need the key.
ROCKSOLID_API_KEY=your_rocksolid_api_key
ROCKSOLID_BASE_URL=https://auto-poster.co.uk/yt_api
ROCKSOLID_AUTH_HEADER=AP_API_KEY

# ---- Instagram Graph API — "Connect Instagram Account" OAuth ----
# One Meta app handles all accounts; each user logs in with their own
# Instagram Business/Creator account (VA Management → Instagram Connect).
# Redirect URI configured in the Meta app must match:
#   ${NEXT_PUBLIC_APP_URL}/api/instagram-graph/callback
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
NEXT_PUBLIC_APP_URL=https://instagram-tool-production-e4f2.up.railway.app

# ---- Instagram Graph API — single global-token account (optional) ----
# Legacy fallback used only when NO account is connected via OAuth above.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ---- Auth (per-user logins + roles) ----
# Leave AUTH_SECRET blank to keep the app open (no login). Set all three to
# turn on logins. AUTH_SECRET = any long random string (signs sessions).
# ADMIN_USERNAME/PASSWORD = your root admin login (you set these; never shared with me).
AUTH_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---- Gemini (AI niche auto-categorization) ----
# Get a key at https://aistudio.google.com/apikey . Used server-side to let
# Gemini watch reel videos and suggest a niche. Optional model override.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# ---- Worker (Railway worker service only) ----
# How often the background refresh cycle runs, in minutes. Lower it (e.g. 20-30)
# while there's a big inspiration-account backlog to enrich, then raise it back.
WORKER_INTERVAL_MINUTES=120
# Run one cycle immediately when the worker boots (1 = yes).
RUN_ON_BOOT=1
# Backlog enrichment per cycle: how many un-scraped inspiration accounts to pull
# each cycle, and how many top reels per account. Keep modest to respect rate limits.
ENRICH_PER_CYCLE=8
ENRICH_REELS_PER_ACCOUNT=8

# ---- Optional: protect the public /api/refresh GET trigger ----
CRON_SECRET=

# ---- Creator discovery (worker) ----
# Comment sections mined per cycle (each = a few scraper calls)
DISCOVER_COMMENT_REELS=3
# Candidates vetted per cycle (each = profile + one reels page)
DISCOVER_VET_PER_CYCLE=5
# Vetting filters
DISCOVER_MIN_FOLLOWERS=1000
DISCOVER_MAX_FOLLOWERS=5000000
DISCOVER_MIN_SCORE=4
# Dedicated discovery worker (Railway service: npm run worker:discovery)
DISCOVERY_INTERVAL_MINUTES=30
# Chrome-extension ingest auth (falls back to CRON_SECRET)
INGEST_SECRET=
# Set to 1 only if you want discovery inside the main refresh worker too
DISCOVER_IN_REFRESH=
DISCOVER_MAX_AGE_DAYS=60
DISCOVER_USE_AI=1
DISCOVER_CLASSIFY_FORMAT=1
DISCOVER_ASSUME_NICHE=1

# ---- Content Pipeline → Airtable sync ----
# The "Ai Reels Workflow Setup" base where briefs get pushed for photo generation.
# Create a personal access token at https://airtable.com/create/tokens
# Scopes: data.records:read, data.records:write
AIRTABLE_PIPELINE_TOKEN=patXXXXXXXXXXXXXX
AIRTABLE_PIPELINE_BASE_ID=appczNKnrkmGGSWWZ
# The table name inside the base (change if yours is named differently)
AIRTABLE_PIPELINE_TABLE=Reels to Generate
